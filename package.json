    "@opentelemetry/sdk-node": "^0.213.0",
    "@sentry/nextjs": "^10.45.0",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.4.0",
    "file-type": "^21.3.3",
    "mongoose": "^9.3.0",
    "next": "^16.1.7",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
