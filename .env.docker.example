# =============================================================================
# Media App — Docker Environment Configuration
# =============================================================================
# Copy this file to .env, then run:
#
#   cp .env.docker.example .env
#   docker compose up -d
#
# Visit http://localhost:3000 to complete setup via the browser wizard.
# Secrets (NEXTAUTH_SECRET, SK_ENCRYPTION_KEY) are auto-generated on first run.
# =============================================================================

# --- MongoDB (Docker Compose service) ----------------------------------------
MONGODB_URI=mongodb://<username>:<password>@mongo:27017/media?authSource=admin

# Credentials for the Docker MongoDB container (ignored if using Atlas)
MONGO_INITDB_ROOT_USERNAME=<username>
MONGO_INITDB_ROOT_PASSWORD=<password>

# --- NextAuth -----------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# NEXTAUTH_SECRET is auto-generated if not set. Override here for production:
# NEXTAUTH_SECRET=your-secret-here

# --- Optional Overrides -------------------------------------------------------
# These are configured via the setup wizard. Set here only to override.
# INSTANCE_NAME=MyMediaApp
# NSFW_ENABLED=false
# THEME_PRIMARY=#3b82f6
# SATSRAIL_API_URL=https://satsrail.com/api/v1
# SK_ENCRYPTION_KEY=your-32-byte-hex-key
# SATSRAIL_WEBHOOK_SECRET=your-webhook-secret
