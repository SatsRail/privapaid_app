# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/media-dev?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Instance Config (white-label)
INSTANCE_NAME=PrivaPaid
INSTANCE_DOMAIN=privapaid.com
NSFW_ENABLED=true
THEME_PRIMARY=#e91e63
LOGO_URL=/logo.svg

# SatsRail API
SATSRAIL_API_URL=https://satsrail.com/api/v1

# Encryption key for sk_live_ storage (32 bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SK_ENCRYPTION_KEY=

# Webhook signature verification
SATSRAIL_WEBHOOK_SECRET=

# Error reporting (optional — get a free DSN at https://sentry.io)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
